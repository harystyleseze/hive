# Hedera Testnet Credentials
# Create accounts at https://portal.hedera.com
# Get HBAR from faucet at https://portal.hedera.com/faucet

# Orchestrator Agent (primary account)
HEDERA_ACCOUNT_ID=0.0.XXXXX
# DER-encoded ECDSA key
HEDERA_PRIVATE_KEY=302e...  

# Market Analyst Agent (separate account, pays 0.1 HBAR per analysis cycle)
MARKET_AGENT_ACCOUNT_ID=0.0.YYYYY
MARKET_AGENT_PRIVATE_KEY=302e...

# Risk Assessor Agent (separate account, pays 0.1 HBAR per risk cycle)
RISK_AGENT_ACCOUNT_ID=0.0.ZZZZZ
RISK_AGENT_PRIVATE_KEY=302e...

# OpenAI API Key
OPENAI_API_KEY=sk-...

# HOL Registry Broker API Key
# Get at: https://hol.org/registry/dashboard
REGISTRY_BROKER_API_KEY=rbk_...

# HCS Topic ID (leave blank — auto-created on first monitor run)
HCS_DECISION_LOG_TOPIC=

# App URL (for agent registration endpoints)
# Set to your deployed URL before running scripts/register-agents.ts for production
# Leave as localhost for local-only development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# HOL Registry UAIDs (output from: npx tsx scripts/register-agents.ts)
ORCHESTRATOR_UAID=
MARKET_ANALYST_UAID=
RISK_ASSESSOR_UAID=

# Public account IDs for UI display
NEXT_PUBLIC_HEDERA_ACCOUNT_ID=0.0.XXXXX
NEXT_PUBLIC_MARKET_AGENT_ACCOUNT_ID=0.0.YYYYY
NEXT_PUBLIC_RISK_AGENT_ACCOUNT_ID=0.0.ZZZZZ

# Hedera network: "testnet" (default) or "mainnet"
HEDERA_NETWORK=testnet
NEXT_PUBLIC_HEDERA_NETWORK=testnet

# Agent payment amount in HBAR per hire cycle
AGENT_PAYMENT_HBAR=0.1

# Risk score thresholds (0-100)
AUTO_PROTECT_THRESHOLD=85
REBALANCE_THRESHOLD=65

# HBAR amount above which to use Hedera Schedule Service (requires user co-sign)
SCHEDULED_TX_THRESHOLD_HBAR=100

# Bonzo Finance lending pool Hedera account ID (testnet: 0.0.4999355)
BONZO_LENDING_POOL_ID=0.0.4999355

# OpenAI model (e.g. gpt-4o, gpt-4o-mini for the chat feature)
OPENAI_MODEL=gpt-4o

# Max Hedera transaction fee cap in HBAR
HEDERA_MAX_TX_FEE_HBAR=2

# Autonomous mode: set to "true" to let Hive operate without any human approval
# false (default) = co-pilot mode: agent proposes, human approves on dashboard
# true = full autonomy: rebalances execute directly, auto-protect defaults ON,
#        deposits bypass action cards, Schedule Service only used if required by protocol
AUTONOMOUS_MODE=false

# HBAR amount deployed per autonomous rebalance cycle (only applies when AUTONOMOUS_MODE=true)
AUTO_REBALANCE_AMOUNT_HBAR=5

# HCS-10 inbound topic ID for the Orchestrator (HOL Registry bounty requirement)
# External agents send messages to this topic to reach the Orchestrator via HCS-10.
# Leave blank — auto-created on first monitor run. Copy the logged ID here afterwards.
HCS10_INBOX_TOPIC=
